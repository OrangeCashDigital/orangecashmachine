# ==============================================================================
# OrangeCashMachine — Variables de entorno
# ==============================================================================
# Uso:
#   cp .env.example .env
#   Editar .env con valores reales antes de levantar Docker.
#
# ⚠️  NUNCA commitear .env al repositorio.
# ==============================================================================

# ── Exchanges ─────────────────────────────────────────────────────────────────
BYBIT_API_KEY=
BYBIT_API_SECRET=

KUCOIN_API_KEY=
KUCOIN_API_SECRET=
KUCOIN_PASSPHRASE=

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=
REDIS_HOST_PORT=6379
REDIS_MAX_MEMORY=256mb

# ── Dagster ───────────────────────────────────────────────────────────────────
DAGSTER_HOST_PORT=3001

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=
GRAFANA_HOST_PORT=3000

# ── Prometheus ────────────────────────────────────────────────────────────────
PROMETHEUS_HOST_PORT=9090

# ── Alertmanager ──────────────────────────────────────────────────────────────
ALERTMANAGER_HOST_PORT=9093
# ALERTMANAGER_WEBHOOK_URL=
# ALERT_EMAIL_TO=
# ALERT_EMAIL_FROM=
# SMTP_HOST=
# SMTP_USER=
# SMTP_PASSWORD=
# SLACK_WEBHOOK_URL=

# ── Pushgateway ───────────────────────────────────────────────────────────────
PUSHGATEWAY_HOST_PORT=9091

# ── Storage ───────────────────────────────────────────────────────────────────
OCM_STORAGE__DATA_LAKE__PATH=/app/data_platform/data_lake

# ── General ───────────────────────────────────────────────────────────────────
OCM_ENV=production
LOG_LEVEL=info

# ── API Gateway ───────────────────────────────────────────────────────────────
# Generar con: python3 -c "import secrets; print(secrets.token_hex(32))"
OCM_API_JWT_SECRET=CHANGE_ME_generate_with_secrets_token_hex_32
# OCM_API_JWT_EXPIRE_MINUTES=60
# OCM_API_RATE_LIMIT_RPM=60
