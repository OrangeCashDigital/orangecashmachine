# ==========================================================
# OrangeCashMachine — Variables de entorno
# ==========================================================
# USO:
#   cp .env.example .env
#   Editar .env con valores reales antes de levantar Docker.
#
# ⚠️  NUNCA commitear .env al repositorio.
# ==========================================================

# ----------------------------------------------------------
# Exchanges — API credentials
# ----------------------------------------------------------
BYBIT_API_KEY=
BYBIT_API_SECRET=

KUCOIN_API_KEY=
KUCOIN_API_SECRET=
KUCOIN_PASSPHRASE=

# ----------------------------------------------------------
# Postgres
# ----------------------------------------------------------
POSTGRES_USER=prefect
POSTGRES_PASSWORD=

# ----------------------------------------------------------
# Prefect
# ----------------------------------------------------------
PREFECT_API_URL=http://localhost:4200/api
PREFECT_HOST_PORT=4200

# ----------------------------------------------------------
# Redis
# ----------------------------------------------------------
REDIS_PASSWORD=
REDIS_HOST_PORT=6379
REDIS_MAX_MEMORY=256mb

# ----------------------------------------------------------
# Grafana
# ----------------------------------------------------------
GRAFANA_USER=admin
GRAFANA_PASSWORD=
GRAFANA_HOST_PORT=3000

# ----------------------------------------------------------
# Prometheus
# ----------------------------------------------------------
PROMETHEUS_HOST_PORT=9090

# ----------------------------------------------------------
# Alertmanager
# ----------------------------------------------------------
ALERTMANAGER_HOST_PORT=9093
# ALERTMANAGER_WEBHOOK_URL=
# ALERT_EMAIL_TO=
# ALERT_EMAIL_FROM=
# SMTP_HOST=
# SMTP_USER=
# SMTP_PASSWORD=
# SLACK_WEBHOOK_URL=

# ----------------------------------------------------------
# Pushgateway
# ----------------------------------------------------------
PUSHGATEWAY_HOST_PORT=9091

# ----------------------------------------------------------
# General
# ----------------------------------------------------------
OCM_ENV=production
LOCAL_DATA_LAKE_PATH=data_platform/local_data_lake
# ── API Gateway ────────────────────────────────────────────────────────────
# Generar con: python3 -c "import secrets; print(secrets.token_hex(32))"
OCM_API_JWT_SECRET=CHANGE_ME_generate_with_secrets_token_hex_32
# OCM_API_JWT_EXPIRE_MINUTES=60
# OCM_API_RATE_LIMIT_RPM=60
# OCM_API_HOST=0.0.0.0
# OCM_API_PORT=8000
# OCM_API_ENV=development
