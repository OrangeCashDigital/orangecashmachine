# Byte-compiled / Python files
__pycache__/
*.py[cod]
*$py.class

# Logs y bases de datos locales
*.log
*.sqlite
*.db
# Configs sensibles
config.json
.env
secrets.yaml
# Carpetas de trabajo de Freqtrade u otras herramientas
user_data/
backtest_results/
strategy_results/
# Datos históricos y parquet del trading
data_platform/data_lake/**/*.parquet
# Prefect temporal
.prefect/
# Archivos del sistema
.DS_Store
Thumbs.db
# Archivos temporales
*.tmp
*.swp
data_platform/data_lake/
requirements.txt.bak
.envrc
refactor.sh
# Lakehouse local de desarrollo (path resuelto por settings.yaml / LOCAL_DATA_LAKE_PATH)
data_platform/local_data_lake/
logs/
# infra/monitoring/ contiene configs versionables — no ignorar
# Ignorar solo artefactos generados dentro de infra/
infra/data/
infra/tmp/
infra/cache/
*.bak
.prefectignore
*.obsolete

# ==============================================================================
# Iceberg runtime — artefactos generados, nunca versionables
# ==============================================================================
# iceberg_catalog/ : SQLite catalog (catalog.db + lock files)
# iceberg_warehouse/: archivos Parquet de datos reales
# Estos viven dentro de data_platform/ (sibling del data_lake).
# SSOT: paths.py los coloca en data_lake_root().parent / "iceberg_*"
data_platform/iceberg_catalog/
data_platform/iceberg_warehouse/

# Archivos temporales de SQLite (journal, WAL)
*.db-journal
*.db-wal
*.db-shm
data/lineage/*.db
data/quality/*.db
.coverage
.import_linter_cache/
.opencode/
AUDITORIA_IMPORT_LINTER.txt
docs/arch/import_graph_*.svg
