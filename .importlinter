[importlinter]
root_package = market_data
include_external_packages = True

# =============================================================================
# BC-01: domain no importa nada del proyecto
# =============================================================================
[importlinter:contract:BC-01-domain-isolation]
name = BC-01: domain es puro — cero dependencias internas
type = forbidden
source_modules =
    market_data.domain
forbidden_modules =
    market_data.application
    market_data.adapters
    market_data.ports
    market_data.infrastructure
    infrastructure

# =============================================================================
# BC-02: ports solo dependen del domain
# =============================================================================
[importlinter:contract:BC-02-ports-isolation]
name = BC-02: ports solo importan domain
type = forbidden
source_modules =
    market_data.ports
forbidden_modules =
    market_data.application
    market_data.adapters
    market_data.infrastructure
    infrastructure

# =============================================================================
# BC-03: application solo importa domain y ports
# =============================================================================
[importlinter:contract:BC-03-application-isolation]
name = BC-03: application no importa adapters ni infrastructure en nivel módulo
type = forbidden
source_modules =
    market_data.application
forbidden_modules =
    market_data.infrastructure
    infrastructure

# Nota: application importa adapters de forma LAZY (dentro de métodos).
# ImportLinter no puede verificar imports lazy — usar tests de arquitectura
# (tests/architecture/test_import_graph.py) para eso.

# =============================================================================
# BC-04: adapters no importan infrastructure directamente
# =============================================================================
[importlinter:contract:BC-04-adapters-no-infra]
name = BC-04: adapters no importan infrastructure — solo ports
type = forbidden
source_modules =
    market_data.adapters
forbidden_modules =
    market_data.infrastructure
    infrastructure

# =============================================================================
# BC-05: infrastructure no importa application (DIP)
# =============================================================================
[importlinter:contract:BC-05-infra-no-application]
name = BC-05: infrastructure no importa application — inversión de dependencias
type = forbidden
source_modules =
    infrastructure
    market_data.infrastructure
forbidden_modules =
    market_data.application

# =============================================================================
# BC-06: infrastructure.dagster solo importa ports y application
# =============================================================================
[importlinter:contract:BC-06-dagster-assets-clean]
name = BC-06: dagster assets solo conocen puertos y use cases
type = forbidden
source_modules =
    infrastructure.dagster.assets
forbidden_modules =
    market_data.infrastructure.storage
    market_data.adapters.outbound.exchange.ccxt_adapter

# =============================================================================
# BC-07: domain no importa librerías de infraestructura
# =============================================================================
[importlinter:contract:BC-07-domain-no-infra-libs]
name = BC-07: domain no importa pyiceberg, redis, ccxt, dagster
type = forbidden
source_modules =
    market_data.domain
forbidden_modules =
    pyiceberg
    redis
    ccxt
    dagster
    sqlalchemy
    boto3

# =============================================================================
# BC-08: capas en orden (layers contract)
# =============================================================================
[importlinter:contract:BC-08-layers]
name = BC-08: orden de capas — domain < ports < application < adapters < infrastructure
type = layers
layers =
    infrastructure
    market_data.adapters
    market_data.application
    market_data.ports
    market_data.domain
ignore_imports =
    market_data.application.use_cases.pipeline_orchestrator -> market_data.adapters

# =============================================================================
# BC-09: exceptions solo importan stdlib
# =============================================================================
[importlinter:contract:BC-09-exceptions-stdlib-only]
name = BC-09: exceptions.py no importa nada del proyecto
type = forbidden
source_modules =
    market_data.exceptions
forbidden_modules =
    market_data.domain
    market_data.ports
    market_data.application
    market_data.adapters
    market_data.infrastructure

# =============================================================================
# BC-10: infrastructure no importa adapters concretos (corregido — completo)
# =============================================================================
[importlinter:contract:BC-10-infra-no-adapters]
name = BC-10: infrastructure depends only on platform abstractions
type = forbidden
source_modules =
    infrastructure
forbidden_modules =
    market_data.adapters.outbound.exchange.ccxt_adapter
    market_data.adapters.outbound.exchange
    market_data.adapters

# =============================================================================
# BC-11: timeouts son SSOT — nadie hardcodea valores
# =============================================================================
[importlinter:contract:BC-11-timeouts-ssot]
name = BC-11: storage e iceberg importan timeouts desde infrastructure.timeouts
type = independence
modules =
    infrastructure.timeouts
    market_data.infrastructure.storage.iceberg.iceberg_storage
